# ── Gmail IMAP ────────────────────────────────────────────────────────────────
IMAP_HOST=imap.gmail.com
IMAP_PORT=993

# Gmail address and App Password (NOT your main password)
# Generate at: https://myaccount.google.com/apppasswords
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=xxxx-xxxx-xxxx-xxxx

# Filter criteria (leave empty to accept all unseen emails with PDFs)
SENDER_FILTER=editor@the-newspaper.co.il
SUBJECT_FILTER=מקומון

# ── Newspaper identity ────────────────────────────────────────────────────────
NEWSPAPER_NAME=שם העיתון
NEWSPAPER_TAGLINE=תיאור קצר של העיתון

# ── Storage paths (on VPS) ────────────────────────────────────────────────────
STORAGE_PATH=/var/www/israelcodes.ovh/newspaper
MANIFEST_PATH=/var/www/israelcodes.ovh/newspaper/manifest.json

# ── Image quality ─────────────────────────────────────────────────────────────
JPG_DPI=150
JPG_QUALITY=85
THUMB_WIDTH=300

# ── IMAP folder for processed emails ─────────────────────────────────────────
PROCESSED_FOLDER=newspaper-processed

# ── Error notifications (optional) ────────────────────────────────────────────
# Leave empty to disable
NOTIFY_EMAIL=your-email@gmail.com
